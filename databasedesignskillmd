Soft Delete & Audit Strategy
Soft Delete Implementation
sql
-- All user-generated content uses soft delete pattern
-- Example: Adding deleted_at column and using views for active records

-- Create view for active records
CREATE VIEW active_users AS
SELECT * FROM users WHERE deleted_at IS NULL;

-- Soft delete function (reusable)
CREATE OR REPLACE FUNCTION soft_delete()
RETURNS TRIGGER AS $$
BEGIN
    NEW.deleted_at = NOW();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Soft delete trigger example
CREATE TRIGGER soft_delete_users
    BEFORE UPDATE ON users
    FOR EACH ROW
    WHEN (NEW.is_active = false AND OLD.is_active = true)
    EXECUTE FUNCTION soft_delete();
Audit Trail Implementation
sql
-- Automatic audit trigger for critical tables
CREATE OR REPLACE FUNCTION audit_trigger_function()
RETURNS TRIGGER AS $$
BEGIN
    INSERT INTO audit_logs (
        action_type, entity_type, entity_id, user_id, user_role,
        old_state, new_state, changes, created_at
    )
    VALUES (
        TG_OP,                    -- INSERT, UPDATE, DELETE
        TG_TABLE_NAME,            -- table name
        COALESCE(NEW.id, OLD.id),
        current_setting('app.current_user_id', true)::UUID,
        current_setting('app.current_user_role', true),
        row_to_json(OLD),
        row_to_json(NEW),
        jsonb_strip_nulls(
            jsonb_build_object(
                'changed_fields', (
                    SELECT jsonb_object_agg(key, value)
                    FROM jsonb_each(to_jsonb(NEW))
                    WHERE to_jsonb(OLD) ->> key != value
                )
            )
        ),
        NOW()
    );
    RETURN COALESCE(NEW, OLD);
END;
$$ LANGUAGE plpgsql;

-- Apply audit trigger to appraisals
CREATE TRIGGER audit_appraisals
    AFTER INSERT OR UPDATE OR DELETE ON appraisals
    FOR EACH ROW
    EXECUTE FUNCTION audit_trigger_function();
